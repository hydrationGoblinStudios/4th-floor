  entry: 0
  exit: 0
  speaker: Ramion
  dialogue: "\"Um pele cinza, no plateia a se esbaldar\r\nQuantas refei\xE7\xF5es
    at\xE9 satisfazer sua tolice?\r\nServiam-lhe caf\xE9, almo\xE7o, lanche e jantar\r\nA
    mem\xF3ria da fome deu lugar \xE0 gulodice\""
  sprite: {fileID: 21300000, guid: 04180ce4ac1c8c14e8a6d315051716ce, type: 3}
